{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://schemafx.com/spec.json",
    "title": "SchemaFX Application Definition",
    "description": "A standard, language-agnostic structure for data-driven applications which allows both humans and systems to understand the outline and functioning of an application without coding knowledge.",
    "type": "object",
    "required": ["schemaVersion", "app", "connectors", "tables"],
    "additionalProperties": {
        "x-": true
    },
    "patternProperties": {
        "^x-": {}
    },
    "properties": {
        "schemaVersion": {
            "type": "string",
            "description": "Specifies which version of the definition to use."
        },
        "app": {
            "$ref": "#/$defs/Metadata"
        },
        "connectors": {
            "type": "object",
            "description": "Defines the available connection sources.",
            "additionalProperties": {
                "$ref": "#/$defs/Connector"
            }
        },
        "tables": {
            "type": "object",
            "description": "Structures the data through tables.",
            "additionalProperties": {
                "$ref": "#/$defs/Table"
            }
        },
        "views": {
            "type": "array",
            "description": "Outlines the list of definitions of the different views in an application.",
            "items": {
                "$ref": "#/$defs/View"
            }
        },
        "workflows": {
            "type": "object",
            "description": "Describe the automated workflows runnable from the application.",
            "additionalProperties": {
                "$ref": "#/$defs/Workflow"
            }
        }
    },
    "$defs": {
        "Metadata": {
            "type": "object",
            "description": "Configures metadata for the application.",
            "required": ["name", "version", "branding"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The application name."
                },
                "description": {
                    "type": "string",
                    "description": "The application description."
                },
                "version": {
                    "type": "string",
                    "description": "The application version."
                },
                "branding": {
                    "$ref": "#/$defs/Branding"
                }
            }
        },
        "Branding": {
            "type": "object",
            "description": "The application's branding configuration.",
            "required": ["primaryColor"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "primaryColor": {
                    "type": "string",
                    "description": "The Hex color code for the primary color."
                },
                "secondaryColor": {
                    "type": "string",
                    "description": "The Hex color code for the secondary color."
                }
            }
        },
        "Connector": {
            "type": "object",
            "description": "Defines a connection source.",
            "required": ["name", "config"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The connector name."
                },
                "description": {
                    "type": "string",
                    "description": "The connector description."
                },
                "config": {
                    "$ref": "#/$defs/ConnectorConfig"
                },
                "auth": {
                    "$ref": "#/$defs/ConnectorAuth"
                }
            }
        },
        "ConnectorConfig": {
            "oneOf": [
                { "$ref": "#/$defs/ConnectorConfigOpenAPI" },
                { "$ref": "#/$defs/ConnectorConfigSQL" },
                { "$ref": "#/$defs/ConnectorConfigFile" },
                { "$ref": "#/$defs/ConnectorConfigGraphQL" },
                { "$ref": "#/$defs/ConnectorConfigREST" },
                { "$ref": "#/$defs/ConnectorConfigOData" }
            ]
        },
        "ConnectorConfigOpenAPI": {
            "type": "object",
            "description": "OpenAPI connector configuration.",
            "required": ["type", "configUrl"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "openapi",
                    "description": "The connector type."
                },
                "configUrl": {
                    "type": "string",
                    "description": "The URL pointing to the OpenAPI configuration document."
                }
            }
        },
        "ConnectorConfigSQL": {
            "type": "object",
            "description": "SQL connector configuration.",
            "required": ["type", "dialect"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "sql",
                    "description": "The connector type."
                },
                "dialect": {
                    "type": "string",
                    "description": "The SQL dialect."
                }
            }
        },
        "ConnectorConfigFile": {
            "type": "object",
            "description": "File connector configuration.",
            "required": ["type", "format"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "file",
                    "description": "The connector type."
                },
                "format": {
                    "type": "string",
                    "description": "The file format."
                },
                "delimiter": {
                    "type": "string",
                    "description": "The delimiter used in the file."
                }
            }
        },
        "ConnectorConfigGraphQL": {
            "type": "object",
            "description": "GraphQL connector configuration.",
            "required": ["type", "endpoint"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "graphql",
                    "description": "The connector type."
                },
                "endpoint": {
                    "type": "string",
                    "description": "The URL of the GraphQL endpoint."
                }
            }
        },
        "ConnectorConfigREST": {
            "type": "object",
            "description": "REST connector configuration.",
            "required": ["type", "baseUrl"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "rest",
                    "description": "The connector type."
                },
                "baseUrl": {
                    "type": "string",
                    "description": "The base URL for the API."
                }
            }
        },
        "ConnectorConfigOData": {
            "type": "object",
            "description": "OData connector configuration.",
            "required": ["type", "serviceUrl"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "odata",
                    "description": "The connector type."
                },
                "serviceUrl": {
                    "type": "string",
                    "description": "The base URL of the OData service."
                },
                "version": {
                    "type": "string",
                    "description": "The OData version."
                }
            }
        },
        "ConnectorAuth": {
            "oneOf": [
                { "$ref": "#/$defs/ConnectorAuthBasic" },
                { "$ref": "#/$defs/ConnectorAuthToken" },
                { "$ref": "#/$defs/ConnectorAuthOAuth2" },
                { "$ref": "#/$defs/ConnectorAuthApiKey" }
            ]
        },
        "ConnectorAuthBasic": {
            "type": "object",
            "description": "Basic authentication configuration.",
            "required": ["type", "fields"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "basic",
                    "description": "The connector auth type."
                },
                "fields": {
                    "type": "array",
                    "description": "The available auth fields.",
                    "items": {
                        "$ref": "#/$defs/Field"
                    }
                }
            }
        },
        "ConnectorAuthToken": {
            "type": "object",
            "description": "Token authentication configuration.",
            "required": ["type", "tokenUrl"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "token",
                    "description": "The connector auth type."
                },
                "tokenUrl": {
                    "type": "string",
                    "description": "The URL to fetch the token."
                },
                "scopes": {
                    "type": "array",
                    "description": "The scopes required for the token.",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "ConnectorAuthOAuth2": {
            "type": "object",
            "description": "OAuth2 authentication configuration.",
            "required": ["type", "authUrl", "tokenUrl"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "oauth2",
                    "description": "The connector auth type."
                },
                "authUrl": {
                    "type": "string",
                    "description": "The URL for authorization."
                },
                "tokenUrl": {
                    "type": "string",
                    "description": "The URL to fetch the token."
                },
                "scopes": {
                    "type": "array",
                    "description": "The scopes required for the token.",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "ConnectorAuthApiKey": {
            "type": "object",
            "description": "API Key authentication configuration.",
            "required": ["type", "keyName", "location"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "apikey",
                    "description": "The connector auth type."
                },
                "keyName": {
                    "type": "string",
                    "description": "The name of the API key."
                },
                "location": {
                    "type": "string",
                    "enum": ["header", "query"],
                    "description": "Where to pass the key."
                }
            }
        },
        "Table": {
            "type": "object",
            "description": "Structures data through a table.",
            "required": ["name", "connector", "path"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The table name."
                },
                "description": {
                    "type": "string",
                    "description": "The table description."
                },
                "connector": {
                    "type": "string",
                    "description": "The source connector."
                },
                "path": {
                    "type": "array",
                    "description": "The path from the connector.",
                    "items": {
                        "type": "string"
                    }
                },
                "fields": {
                    "type": "array",
                    "description": "The list of available fields.",
                    "items": {
                        "$ref": "#/$defs/Field"
                    }
                },
                "actions": {
                    "type": "array",
                    "description": "The list of available actions.",
                    "items": {
                        "$ref": "#/$defs/Action"
                    }
                }
            }
        },
        "Field": {
            "type": "object",
            "description": "Defines a field.",
            "required": ["id", "name", "config"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "id": {
                    "type": "string",
                    "description": "The field id. Must be unique across all fields."
                },
                "name": {
                    "type": "string",
                    "description": "The field name."
                },
                "description": {
                    "type": "string",
                    "description": "The field description."
                },
                "primary": {
                    "type": "boolean",
                    "description": "Whether the field is a key."
                },
                "required": {
                    "type": "boolean",
                    "description": "Whether the field is required."
                },
                "config": {
                    "$ref": "#/$defs/FieldConfig"
                }
            }
        },
        "FieldConfig": {
            "oneOf": [
                { "$ref": "#/$defs/FieldConfigString" },
                { "$ref": "#/$defs/FieldConfigNumber" },
                { "$ref": "#/$defs/FieldConfigBoolean" },
                { "$ref": "#/$defs/FieldConfigDate" },
                { "$ref": "#/$defs/FieldConfigJSON" }
            ]
        },
        "FieldConfigString": {
            "type": "object",
            "description": "String field configuration.",
            "required": ["type"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "string",
                    "description": "The field type."
                }
            }
        },
        "FieldConfigNumber": {
            "type": "object",
            "description": "Number field configuration.",
            "required": ["type"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "number",
                    "description": "The field type."
                }
            }
        },
        "FieldConfigBoolean": {
            "type": "object",
            "description": "Boolean field configuration.",
            "required": ["type"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "boolean",
                    "description": "The field type."
                }
            }
        },
        "FieldConfigDate": {
            "type": "object",
            "description": "Date field configuration.",
            "required": ["type"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "date",
                    "description": "The field type."
                }
            }
        },
        "FieldConfigJSON": {
            "type": "object",
            "description": "JSON field configuration.",
            "required": ["type"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "json",
                    "description": "The field type."
                }
            }
        },
        "Action": {
            "type": "object",
            "description": "Defines an action.",
            "required": ["id", "name", "config"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "id": {
                    "type": "string",
                    "description": "The action id. Must be unique across all actions."
                },
                "name": {
                    "type": "string",
                    "description": "The action name."
                },
                "description": {
                    "type": "string",
                    "description": "The action description."
                },
                "config": {
                    "$ref": "#/$defs/ActionConfig"
                }
            }
        },
        "ActionConfig": {
            "oneOf": [
                { "$ref": "#/$defs/ActionConfigAdd" },
                { "$ref": "#/$defs/ActionConfigUpdate" },
                { "$ref": "#/$defs/ActionConfigDelete" },
                { "$ref": "#/$defs/ActionConfigProcess" },
                { "$ref": "#/$defs/ActionConfigWorkflow" }
            ]
        },
        "ActionConfigAdd": {
            "type": "object",
            "description": "Add action configuration.",
            "required": ["type"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "add",
                    "description": "The action type."
                }
            }
        },
        "ActionConfigUpdate": {
            "type": "object",
            "description": "Update action configuration.",
            "required": ["type"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "update",
                    "description": "The action type."
                },
                "fields": {
                    "type": "array",
                    "description": "The fields to avail for quick edit.",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "ActionConfigDelete": {
            "type": "object",
            "description": "Delete action configuration.",
            "required": ["type"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "delete",
                    "description": "The action type."
                }
            }
        },
        "ActionConfigProcess": {
            "type": "object",
            "description": "Process action configuration. A process action is an action which processes multiple actions.",
            "required": ["type", "actions"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "process",
                    "description": "The action type."
                },
                "actions": {
                    "type": "array",
                    "description": "A list of actions to run. Those MUST be processed in order.",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "ActionConfigWorkflow": {
            "type": "object",
            "description": "Workflow action configuration. A workflow action is an action which runs a workflow.",
            "required": ["type", "workflow"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "workflow",
                    "description": "The action type."
                },
                "workflow": {
                    "type": "string",
                    "description": "The workflow to run."
                }
            }
        },
        "View": {
            "type": "object",
            "description": "Defines a view.",
            "required": ["id", "name", "table", "config"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "id": {
                    "type": "string",
                    "description": "The view id. Must be unique across all views."
                },
                "name": {
                    "type": "string",
                    "description": "The view name."
                },
                "description": {
                    "type": "string",
                    "description": "The view description."
                },
                "table": {
                    "type": "string",
                    "description": "The view source Table's id."
                },
                "config": {
                    "$ref": "#/$defs/ViewConfig"
                }
            }
        },
        "ViewConfig": {
            "oneOf": [
                { "$ref": "#/$defs/ViewConfigTable" },
                { "$ref": "#/$defs/ViewConfigForm" },
                { "$ref": "#/$defs/ViewConfigDetail" }
            ]
        },
        "ViewConfigTable": {
            "type": "object",
            "description": "Table view configuration.",
            "required": ["type", "fields"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "table",
                    "description": "The view type."
                },
                "fields": {
                    "type": "array",
                    "description": "The list of fields to display. Those MUST be displayed in order.",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "ViewConfigForm": {
            "type": "object",
            "description": "Form view configuration.",
            "required": ["type", "fields"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "form",
                    "description": "The view type."
                },
                "fields": {
                    "type": "array",
                    "description": "The list of fields to display. Those MUST be displayed in order.",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "ViewConfigDetail": {
            "type": "object",
            "description": "Detail view configuration.",
            "required": ["type", "fields"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "detail",
                    "description": "The view type."
                },
                "fields": {
                    "type": "array",
                    "description": "The list of fields to display. Those MUST be displayed in order.",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "Workflow": {
            "type": "object",
            "description": "Describes an automated workflow runnable from the application.",
            "required": ["name", "trigger", "actions"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The workflow name."
                },
                "description": {
                    "type": "string",
                    "description": "The workflow description."
                },
                "trigger": {
                    "$ref": "#/$defs/WorkflowTrigger"
                },
                "actions": {
                    "type": "array",
                    "description": "The workflow actions. Those MUST be processed in order.",
                    "items": {
                        "$ref": "#/$defs/WorkflowAction"
                    }
                }
            }
        },
        "WorkflowTrigger": {
            "type": "object",
            "description": "Defines a workflow trigger.",
            "required": ["id", "name", "config"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "id": {
                    "type": "string",
                    "description": "The trigger id. Must be unique across all workflow triggers."
                },
                "name": {
                    "type": "string",
                    "description": "The trigger name."
                },
                "description": {
                    "type": "string",
                    "description": "The trigger description."
                },
                "config": {
                    "$ref": "#/$defs/WorkflowTriggerConfig"
                }
            }
        },
        "WorkflowTriggerConfig": {
            "oneOf": [{ "$ref": "#/$defs/WorkflowTriggerConfigData" }]
        },
        "WorkflowTriggerConfigData": {
            "type": "object",
            "description": "A workflow trigger which depends on a data change.",
            "required": ["type", "table", "event"],
            "additionalProperties": false,
            "patternProperties": {
                "^x-": {}
            },
            "properties": {
                "type": {
                    "const": "data",
                    "description": "The trigger type."
                },
                "table": {
                    "type": "string",
                    "description": "The trigger source Table's id."
                },
                "event": {
                    "type": "array",
                    "description": "The list of trigger events.",
                    "items": {
                        "type": "string",
                        "enum": ["add", "update", "delete"]
                    }
                }
            }
        },
        "WorkflowAction": {
            "oneOf": [
                {
                    "type": "string",
                    "description": "An id referencing an Action."
                },
                {
                    "$ref": "#/$defs/Action"
                }
            ],
            "description": "A workflow action is either a string as an id for an Action or as an Action object itself."
        }
    }
}
